{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "tech-stack/skill-logo",
	"version": "0.1.3",
	"title": "Skill Logo",
	"category": "widgets",
	"icon": "editor-code",
	"description": "Displays configurable SVG logos and badges.",
	"example": {},
	"supports": {
		"html": false,
		"align": [ "wide", "full" ]
	},
	"attributes": {
		"logos": {
			"type": "array",
			"items": {
				"type": "string"
			},
			"default": []
		},
		"size": {
			"type": "number"
		},
		"gap": {
			"type": "number"
		}
	},
	"textdomain": "skill-logo",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
	"viewScript": "file:./view.js"
}
